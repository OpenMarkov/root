@startuml r7-after
' ============================================================
' R7 After -- VisualNetwork decoupled from MainGUI
' ============================================================

skinparam defaultFontName Courier
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 30
skinparam dpi 150

skinparam class {
  BackgroundColor<<model>> #D8FFD8
  BorderColor<<model>> #44AA44
  BackgroundColor<<ui>> #E8E8FF
  BorderColor<<ui>> #6666AA
}

class VisualNetwork <<model>> {
  <b>Pure view-model (no UI deps)</b>
  __
  - probNet: ProbNet
  __
  + afterEditExecutes(PNEdit)
  + afterUndoingEdit(PNEdit)
  + afterRedoingEdit(PNEdit)
  - refreshUI()
  ..
  constructVisualInfo()
  visualDecisionNodeRefresh()
}

class MainPanelMenuAssistant <<ui>> {
  <b>Centralized undo/redo state</b>
  __
  + undoableEditHappened()
  - updateUndoRedo(canUndo, canRedo)
  ..
  setOptionEnabled(UNDO, canUndo)
  setOptionEnabled(REDO, canRedo)
  → updates menus AND toolbars
}

class PNESupport <<model>> {
  + addListener(PNEditListener)
  notifies all listeners
}

PNESupport ..> VisualNetwork : PNEditListener
PNESupport ..> MainPanelMenuAssistant : PNEditListener

note bottom of VisualNetwork
  No dependency on MainGUI,
  MainPanel, or EditionToolBar.
  Undo/redo button state is
  managed solely by
  MainPanelMenuAssistant.
end note

@enduml
