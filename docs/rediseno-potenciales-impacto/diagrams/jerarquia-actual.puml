@startuml jerarquia-actual
' ============================================================
'  Jerarquia ACTUAL del paquete potential (post Rediseno 1)
'  Ya con interfaces de capacidad extraidas
' ============================================================

skinparam defaultFontName Courier
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 45
skinparam dpi 150
hide empty methods
hide empty fields

skinparam class {
    BackgroundColor<<cap>> #E8F4FF
    BorderColor<<cap>> #4477AA
    BackgroundColor<<base>> #F0F0F0
    BorderColor<<base>> #555555
    BackgroundColor<<table>> #E8FFE8
    BorderColor<<table>> #44AA44
    BackgroundColor<<symbolic>> #FFF8DC
    BorderColor<<symbolic>> #AA8844
    BackgroundColor<<distrib>> #FFEEEE
    BorderColor<<distrib>> #AA4444
}

package "potential" {

    abstract class Potential <<base>> {
        #variables : List<Variable>
        #role : PotentialRole
        #criterion : Criterion
        +properties : Map  ' publico !
    }

    interface Projectable <<cap>>
    interface Reorderable <<cap>>
    interface Scalable <<cap>>
    interface StrategyCarrier <<cap>>
    interface UncertaintyCarrier <<cap>>
    interface CEUtilityPotential <<cap>>

    abstract class AbstractIndexedPotential <<base>>

    class TablePotential <<table>>
    class UncertainTablePotential <<table>> {
        +uncertainValues : UncertainValue[]  ' publico volatile
    }
    class StrategicTablePotential <<table>> {
        +strategyTrees : StrategyTree[]  ' publico volatile
    }
    class AugmentedProbTable <<table>>
    class "GTablePotential<E>" as GTablePotential <<table>>

    class UniformPotential <<symbolic>>
    class DeltaPotential <<symbolic>>
    class SameAsPrevious <<symbolic>>
    class CycleLengthShift <<symbolic>>
    class ProductPotential <<symbolic>>
    class SumPotential <<symbolic>>
    class ExactDistrPotential <<symbolic>>
    class AugmentedProbTablePotential <<symbolic>>

    abstract class GLMPotential <<distrib>>
    class FunctionPotential <<distrib>>
    class LinearCombinationPotential <<distrib>>
    class ExponentialPotential <<distrib>>
    class WeibullHazardPotential <<distrib>>
    class ExponentialHazardPotential <<distrib>>
    class BinomialPotential <<distrib>>
    class ConditionalGaussianPotential <<distrib>>
    class DiscretizedCauchyPotential <<distrib>>
    class UnivariateDistrPotential <<distrib>>

    abstract class ICIPotential <<symbolic>>
    abstract class MinMaxPotential <<symbolic>>
    class MaxPotential <<symbolic>>
    class MinPotential <<symbolic>>
    class TuningPotential <<symbolic>>

    class TreeADDPotential <<symbolic>>
    class StrategyTree <<symbolic>>
    class SDAGStrategyTree <<symbolic>>

    Potential <|-- AbstractIndexedPotential
    AbstractIndexedPotential <|-- TablePotential
    AbstractIndexedPotential <|-- GTablePotential
    TablePotential <|-- UncertainTablePotential
    TablePotential <|-- StrategicTablePotential
    UncertainTablePotential <|-- AugmentedProbTable
    Potential <|-- UniformPotential
    Potential <|-- DeltaPotential
    Potential <|-- SameAsPrevious
    Potential <|-- CycleLengthShift
    Potential <|-- ProductPotential
    Potential <|-- SumPotential
    Potential <|-- ExactDistrPotential
    Potential <|-- AugmentedProbTablePotential
    Potential <|-- GLMPotential
    GLMPotential <|-- FunctionPotential
    GLMPotential <|-- LinearCombinationPotential
    GLMPotential <|-- ExponentialPotential
    Potential <|-- WeibullHazardPotential
    WeibullHazardPotential <|-- ExponentialHazardPotential
    Potential <|-- BinomialPotential
    Potential <|-- ConditionalGaussianPotential
    Potential <|-- DiscretizedCauchyPotential
    Potential <|-- UnivariateDistrPotential
    Potential <|-- ICIPotential
    ICIPotential <|-- MinMaxPotential
    ICIPotential <|-- TuningPotential
    MinMaxPotential <|-- MaxPotential
    MinMaxPotential <|-- MinPotential
    Potential <|-- TreeADDPotential
    TreeADDPotential <|-- StrategyTree
    StrategyTree <|-- SDAGStrategyTree

    TablePotential ..|> Projectable
    TablePotential ..|> Reorderable
    TablePotential ..|> Scalable
    TablePotential ..|> CEUtilityPotential
    UncertainTablePotential ..|> UncertaintyCarrier
    StrategicTablePotential ..|> StrategyCarrier
    GTablePotential ..|> CEUtilityPotential
    UniformPotential ..|> Projectable
    DeltaPotential ..|> Projectable
    DeltaPotential ..|> Scalable
    ICIPotential ..|> Projectable
    LinearCombinationPotential ..|> Scalable
}

note right of Potential #FFEECC
  <b>Aún en la base abstracta:</b>
  - tableProject (default lanza)
  - reorder (default lanza)
  - scalePotential (default lanza)
  - sampleConditionedVariable
  - getProbability (default 0)
  - properties: publico
end note

note right of TablePotential #FFEECC
  getValues() devuelve la
  referencia viva al array.
  315 lecturas externas
  + 7 escrituras directas
  via getValues()[i] = ...
end note

@enduml
