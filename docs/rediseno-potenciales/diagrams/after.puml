@startuml after
' ============================================================
' Jerarquia DESPUES del Rediseno 1 (Fases 1-4 completadas)
' Colores:
'   verde     = clases nuevas
'   amarillo  = clases modificadas
'   gris      = clases sin cambios
' ============================================================

skinparam defaultFontName Courier
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 40
skinparam dpi 150

hide empty methods

skinparam class {
    BackgroundColor<<new>> #D4EDDA
    BorderColor<<new>> #28A745
    BackgroundColor<<modified>> #FFF3CD
    BorderColor<<modified>> #D4A017
    BackgroundColor<<unchanged>> #E8E8FF
    BorderColor<<unchanged>> #6666AA
}

package "potential" {

    abstract class Potential <<unchanged>> {
        #variables : List<Variable>
        #role : PotentialRole
    }

    abstract class AbstractIndexedPotential <<new>> {
        #dimensions : int[]
        #offsets : int[]
        #initialPosition : int
        #tableSize : int
        --
        +getPosition(int[]) : int
        +getPosition(EvidenceCase) : int
        +getConfiguration(int) : int[]
        +getAccumulatedOffsets(...) : int[]
        +{static} calculateDimensions(...)
        +{static} calculateOffsets(...)
        +{static} computeTableSize(...)
    }

    class TablePotential <<modified>> {
        +values : double[]
        --
        +tableProject(...)
        +reorder(...)
        +deepCopy(...)
        +getUncertainValues() : null
        +hasInterventions() : false
        +isUncertain() : false
    }

    class StrategicTablePotential <<new>> {
        +strategyTrees : StrategyTree[]
        --
        +hasInterventions() : true
        +hasInterventionForDecision(...)
        +deepCopy(...)
        +reorder(...)
        +tableProject(...)
    }

    class UncertainTablePotential <<new>> {
        +uncertainValues : UncertainValue[]
        --
        +isUncertain() : true
        +getUncertainValues()
        +setUncertainValues(...)
        +deepCopy(...)
        +reorder(...)
        +tableProject(...)
    }

    class "GTablePotential<E>" as GTablePotential <<unchanged>> {
        +elementTable : List<E>
        --
        (Fase 5 pendiente:
         cambiar la superclase a
         AbstractIndexedPotential)
    }

    class AugmentedProbTable <<modified>> {
        +distributions : ...
        --
        (ahora extiende
         UncertainTablePotential)
    }

    class ExactDistrPotential <<modified>> {
        -tablePotential : TablePotential
        --
        (tablePotential interno ahora
         es UncertainTablePotential)
    }

    Potential <|-- AbstractIndexedPotential
    AbstractIndexedPotential <|-- TablePotential
    TablePotential <|-- StrategicTablePotential
    TablePotential <|-- UncertainTablePotential
    TablePotential <|-- GTablePotential
    UncertainTablePotential <|-- AugmentedProbTable

    note left of TablePotential #D4EDDA
      <b>TablePotential simplificado</b>:
      Solo contiene <b>values[]</b>.
      Sin campos opcionales.
      Sin bloques condicionales triples.
      Sin bug de copia superficial.
    end note

    note left of AbstractIndexedPotential #D4EDDA
      <b>Despacho virtual</b>:
      Los metodos base (getUncertainValues,
      hasInterventions, isUncertain) devuelven
      valores por defecto.
      Las subclases los sobreescriben.
      El codigo cliente no necesita
      instanceof ni casts.
    end note

}

legend right
  |= Color |= Significado |
  |<back:#D4EDDA>  | Clase nueva |
  |<back:#FFF3CD>  | Clase modificada |
  |<back:#E8E8FF>  | Clase sin cambios |
endlegend

@enduml
