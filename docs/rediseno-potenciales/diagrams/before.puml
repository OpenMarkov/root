@startuml before
' ============================================================
' Jerarquia ANTES del Rediseno 1
' Colores: rojo = clases con problemas, gris = sin cambios
' ============================================================

skinparam defaultFontName Courier
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50
skinparam dpi 150

hide empty methods

skinparam class {
    BackgroundColor<<problem>> #FFDDD8
    BorderColor<<problem>> #CC4444
    BackgroundColor<<neutral>> #E8E8FF
    BorderColor<<neutral>> #6666AA
}

package "potential" {

    abstract class Potential <<neutral>> {
        #variables : List<Variable>
        #role : PotentialRole
        --
        +{abstract} tableProject(...)
        +{abstract} reorder(...)
        +{abstract} deepCopy(...)
        +{abstract} copy()
        +{abstract} isUncertain()
    }

    class TablePotential <<problem>> {
        +values : double[]
        **+strategyTrees : StrategyTree[]**
        **+uncertainValues : UncertainValue[]**
        #dimensions : int[]
        #offsets : int[]
        #initialPosition : int
        #tableSize : int
        --
        +tableProject(...)  // triple logica
        +reorder(...)       // triple logica
        +deepCopy(...)      // triple logica
        +hasInterventions()
        +isUncertain()
        +getUncertainValues()
        +sample(...)
        -copyValuesInterventionsAndUncertainValues(...)
    }

    class "GTablePotential<E>" as GTablePotential <<problem>> {
        +elementTable : List<E>
        --
        super(vars, **null**)
        **values[] reservado pero no usado**
    }

    class AugmentedProbTable <<neutral>> {
        +distributions : ...
    }

    Potential <|-- TablePotential
    TablePotential <|-- GTablePotential
    TablePotential <|-- AugmentedProbTable

    note right of TablePotential #FFDDD8
      <b>Problema 1</b>: Tres responsabilidades
      mezcladas en una sola clase.

      <b>strategyTrees</b> y <b>uncertainValues</b>
      son <b>null</b> en la inmensa mayoria
      de las instancias.

      Todos los metodos (tableProject,
      reorder, deepCopy) contienen
      bloques condicionales triples.

      <b>Bug critico</b>: El constructor de copia
      hace alias mutable compartido:

      <code>uncertainValues = pot.uncertainValues;</code>
      <code>strategyTrees = pot.strategyTrees;</code>

      Modificar la copia corrompe el original.
    end note

    note right of GTablePotential #FFDDD8
      <b>Problema 3</b>: GTablePotential hereda
      un array <b>values[]</b> que nunca utiliza.
      Desperdicio de memoria de
      <b>tableSize * 8 bytes</b> por instancia.
    end note

}

@enduml
