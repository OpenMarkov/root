@startuml r3-after
' ============================================================
' R3 After -- Link returns TablePotential, no casts needed
' ============================================================

skinparam defaultFontName Courier
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50
skinparam dpi 150

skinparam class {
  BackgroundColor<<core>> #E8E8FF
  BorderColor<<core>> #6666AA
  BackgroundColor<<gui>> #FFF8E0
  BorderColor<<gui>> #AA9944
  BackgroundColor<<fixed>> #D8FFD8
  BorderColor<<fixed>> #44AA44
}

package "org.openmarkov.core" {
  abstract class Potential <<core>> {
    + getValues(): double[]
    + copy(): Potential
  }

  class TablePotential <<core>> {
    + getValues(): double[]
    + copy(): Potential
  }

  class "Link<Node>" as Link <<fixed>> {
    - restrictionsPotential: TablePotential
    __
    + getRestrictionsPotential(): <color:#44AA44><b>TablePotential</b></color>
    + setRestrictionsPotential(<color:#44AA44><b>TablePotential</b></color>): void
  }

  Potential <|-- TablePotential
}

package "org.openmarkov.gui" {
  class LinkRestrictionPotentialValueEdit <<fixed>> {
    <color:#44AA44>no casts needed</color>
  }

  class LinkRestrictionPanel <<fixed>> {
    <color:#44AA44>no casts needed</color>
  }

  class LinkRestrictionValuesTable <<fixed>> {
    <color:#44AA44>no casts needed</color>
  }

  class RemoveLinkRestrictionEdit <<fixed>> {
    <color:#44AA44>fields typed as TablePotential</color>
  }
}

Link ..> TablePotential : returns

LinkRestrictionPotentialValueEdit ..> Link
LinkRestrictionPanel ..> Link
LinkRestrictionValuesTable ..> Link
RemoveLinkRestrictionEdit ..> Link

note bottom of Link
  API now matches field type.
  15 of 16 casts eliminated.
end note

@enduml
